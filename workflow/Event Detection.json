    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst today = new Date().toISOString().split('T')[0];\n\nconst events = [];\n\nitems.forEach(item => {\n  const data = item.json;\n  const username = data.username;\n  const platform = data.platform;\n  const bio = data.bio || '';\n\n  // EVENT 1: Followed but no DM sent yet → \"new_follower\" trigger\n  const followedButNoDM = data.follow_status === 'followed' && data.dm_sent === 'no';\n\n  // EVENT 2: Bio has AI-relevant keywords AND DM already sent → \"bio_update\" trigger\n  // Simulates: lead updated their bio with AI-relevant content → re-engage them\n  const aiKeywords = ['automation', 'ai', 'chatbot', 'saas', 'digital', 'agency', 'founder'];\n  const bioHasKeywords = aiKeywords.some(k => bio.toLowerCase().includes(k));\n  const bioUpdateTrigger = bioHasKeywords && data.dm_sent === 'yes' && !data.followup_dm_text;\n\n  if (followedButNoDM) {\n    events.push({\n      json: {\n        username, platform, bio,\n        event_type: 'new_follower',\n        event_description: `${username} is now followed — ready for first DM`,\n        trigger_date: today,\n        profile_url: data.profile_url,\n        action: 'send_dm'\n      }\n    });\n  } else if (bioUpdateTrigger) {\n    events.push({\n      json: {\n        username, platform, bio,\n        event_type: 'bio_update',\n        event_description: `${username} bio has AI-relevant keywords — re-engage`,\n        trigger_date: today,\n        profile_url: data.profile_url,\n        action: 'send_followup'\n      }\n    });\n  }\n});\n\nif (events.length === 0) {\n  return [{ json: { message: 'No events detected', date: today } }];\n}\n\nreturn events;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        48
      ],
