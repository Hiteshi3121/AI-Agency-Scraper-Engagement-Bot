        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an outreach specialist for an AI agency. Write a SHORT follow-up DM under 100 words. Be friendly, not pushy. Reference AI automation benefits. Make it feel different from a first message.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a follow-up DM to {{ $json.username }} whose bio mentions AI-relevant keywords: {{ $('Event Detector').item.json.bio.replace(/\\n/g, ' ').replace(/\\\"/g, '') }}. They previously received a DM from us. Re-engage them by referencing their interest in AI/automation. Keep it under 100 words, friendly, not pushy.\"\n    }\n  ],\n  \"max_tokens\": 150,\n  \"temperature\": 0.9\n}",
        "options": {}
      },
