        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an outreach specialist for an AI agency. Write a SHORT follow-up message under 100 words. Be friendly, not pushy. Reference AI automation benefits.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Write a follow-up DM to {{ $json.username }} who hasn't replied in {{ $json.hours_since_dm }} hours. Their bio: {{ $json.bio.replace(/\\n/g, ' ').replace(/\\\"/g, '') }}. Keep it very short and different from the first message.\"\n    }\n  ],\n  \"max_tokens\": 150,\n  \"temperature\": 0.9\n}",
