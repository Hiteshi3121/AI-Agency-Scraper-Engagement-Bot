    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\n\nif (!groqResponse.choices) {\n  return [{ json: { error: 'No Groq response' } }];\n}\n\nconst dmText = groqResponse.choices[0].message.content;\n\nlet username = 'unknown';\ntry {\n  username = $('timer code').item.json.username\n    || $('loop').item.json.username\n    || 'unknown';\n} catch(e) {\n  username = 'unknown';\n}\n\nreturn [{\n  json: {\n    username: username,\n    followup_dm_text: dmText,\n    followup_dm_sent_date: new Date().toISOString().split('T')[0]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        -88
      ],
      "id": "f5688884-b01c-4a86-9cf5-069f062e2ce9",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst today = new Date();\n\nconst needsFollowUp = rows.filter(row => {\n  const dmDate = new Date(row.json.dm_sent_date);\n  const hoursSinceDM = Math.floor((today - dmDate) / (1000 * 60 * 60));\n  const noReply = row.json.reply_received === 'no';\n  const dmSent = row.json.dm_sent === 'yes';\n  \n  return dmSent && noReply && hoursSinceDM >= 48;\n});\n\nif (needsFollowUp.length === 0) {\n  return [{ json: { message: 'No follow-ups needed today' } }];\n}\n\nreturn needsFollowUp.map(row => ({\n  json: {\n    username: row.json.username,\n    platform: row.json.platform,\n    bio: row.json.bio,\n    original_dm: row.json.dm_text,\n    hours_since_dm: Math.floor(\n      (today - new Date(row.json.dm_sent_date)) / (1000 * 60 * 60)\n    )\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
